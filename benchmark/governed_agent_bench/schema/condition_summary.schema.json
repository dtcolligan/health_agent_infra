{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/governed-agent-bench/condition_summary.schema.json",
  "title": "GovernedAgentBench Pilot Condition Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "system_id",
    "runtime_mode",
    "cell_outcome",
    "abort_reason",
    "offending_mechanism",
    "disposition",
    "raw_cost_usd",
    "cost_basis",
    "raw_wall_time_min",
    "per_mechanism_cost_usd",
    "diagnostic_non_load_bearing_cost_usd",
    "cost_reconciliation",
    "tasks_run",
    "reps_completed",
    "reps_partial",
    "reps_context_overflow",
    "reps_provider_filtered",
    "reps_length_truncation"
  ],
  "properties": {
    "schema_version": {
      "const": "governed_agent_bench.condition_summary.v1"
    },
    "system_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_mode": {
      "$ref": "#/$defs/runtime_mode"
    },
    "cell_outcome": {
      "type": "string",
      "enum": ["completed", "halted", "aborted", "paused", "skipped_no_in_scope_tasks"]
    },
    "abort_reason": {
      "anyOf": [{"$ref": "#/$defs/abort_reason"}, {"type": "null"}]
    },
    "offending_mechanism": {
      "type": ["string", "null"]
    },
    "disposition": {
      "$ref": "#/$defs/condition_disposition"
    },
    "raw_cost_usd": {
      "type": ["number", "null"]
    },
    "cost_basis": {
      "type": "string",
      "enum": ["per_step_usd", "condition_level"]
    },
    "raw_wall_time_min": {
      "type": "number",
      "minimum": 0
    },
    "per_mechanism_cost_usd": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "diagnostic_non_load_bearing_cost_usd": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "cost_reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "per_step_cost_available",
        "costed_step_count",
        "per_step_cost_usd",
        "allocated_cost_usd",
        "raw_cost_usd",
        "allocated_minus_per_step_delta_usd",
        "raw_minus_per_step_delta_usd",
        "invariant_holds",
        "raw_cost_matches_per_step_sum"
      ],
      "properties": {
        "per_step_cost_available": {
          "type": "boolean"
        },
        "costed_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "per_step_cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "allocated_cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "raw_cost_usd": {
          "type": ["number", "null"]
        },
        "allocated_minus_per_step_delta_usd": {
          "type": ["number", "null"]
        },
        "raw_minus_per_step_delta_usd": {
          "type": ["number", "null"]
        },
        "invariant_holds": {
          "type": ["boolean", "null"]
        },
        "raw_cost_matches_per_step_sum": {
          "type": ["boolean", "null"]
        }
      }
    },
    "tasks_run": {
      "type": "integer",
      "minimum": 0
    },
    "reps_completed": {
      "type": "integer",
      "minimum": 0
    },
    "reps_partial": {
      "type": "integer",
      "minimum": 0
    },
    "reps_context_overflow": {
      "type": "integer",
      "minimum": 0,
      "description": "Reps stopped by a provider HTTP 422 context-overflow rejection. Reportable outcome: neither a pass nor a model task failure."
    },
    "reps_provider_filtered": {
      "type": "integer",
      "minimum": 0,
      "description": "Reps stopped by a provider-side safety filter (finish_reason content_filter/refusal/safety or message refusal flag). Reportable outcome: neither a pass nor a model task failure."
    },
    "reps_length_truncation": {
      "type": "integer",
      "minimum": 0,
      "description": "Reps stopped by a max_tokens budget truncation (finish_reason=length). Harness budget artifact: neither a pass nor a model task failure."
    }
  },
  "$defs": {
    "runtime_mode": {
      "type": "string",
      "enum": [
        "full_contract",
        "no_validation",
        "no_agent_safe",
        "no_proposal_gate",
        "no_refusal",
        "no_audit_chain",
        "no_runtime_enforcement"
      ]
    },
    "abort_reason": {
      "type": "string",
      "enum": [
        "contamination_detected",
        "full_contract_unexpected_marker",
        "full_contract_breach",
        "clinical_claim"
      ]
    },
    "condition_disposition": {
      "type": "string",
      "enum": [
        "completed",
        "skipped_no_in_scope_tasks",
        "cost_halt",
        "wall_halt",
        "adapter_halt",
        "fixture_build_error",
        "provider_outage",
        "contamination_detected",
        "full_contract_unexpected_marker",
        "full_contract_breach",
        "clinical_claim"
      ]
    }
  }
}
