{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/governed-agent-bench/task.schema.json",
  "title": "GovernedAgentBench Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "level",
    "title",
    "runtime",
    "contract_version",
    "user_prompt",
    "allowed_context",
    "expected_behavior",
    "metrics",
    "load_bearing_mechanisms",
    "runtime_modes_in_scope"
  ],
  "properties": {
    "schema_version": {
      "const": "governed_agent_bench.task.v2"
    },
    "task_id": {
      "type": "string",
      "pattern": "^gab_l[1-7]_[a-z0-9_]+$"
    },
    "level": {
      "type": "string",
      "enum": ["L1", "L2", "L3", "L4", "L5", "L6", "L7"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "user_prompt": {
      "type": "string",
      "minLength": 1
    },
    "allowed_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "manifest_ref": {
          "type": "string"
        },
        "read_surface_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "fixture_refs": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "expected_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["success", "refusal", "user_input", "partial_success"]
        },
        "command_sequence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command"],
            "properties": {
              "command": {"type": "string"},
              "required": {"type": "boolean", "default": true},
              "notes": {"type": "string"}
            }
          }
        },
        "must_not_call": {
          "type": "array",
          "items": {"type": "string"}
        },
        "refusal_reason": {
          "type": "string"
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "task_success",
          "valid_command_rate",
          "correct_command_rate",
          "hallucinated_command_rate",
          "schema_validity",
          "refusal_accuracy",
          "unsafe_action_rate",
          "direct_state_write_attempt_rate",
          "clinical_claim_rate",
          "unsupported_narration_rate",
          "audit_reference_faithfulness",
          "exit_code_recovery_accuracy",
          "drift_robustness"
        ]
      }
    },
    "load_bearing_mechanisms": {
      "type": "array",
      "description": "Ablatable runtime mechanisms this task is designed to exercise. May be empty if the task is not a mechanism-stress task. Mechanisms enumerated here MUST appear in the trajectory/score mechanism enum (M4-M8). Held-constant harness controls (M1-M3) are not part of this enum.",
      "items": {
        "type": "string",
        "enum": [
          "validation",
          "agent_safe",
          "proposal_gate",
          "refusal",
          "audit_chain"
        ]
      }
    },
    "runtime_modes_in_scope": {
      "type": "array",
      "description": "Runtime modes under which this task produces informative scores. Empty array means all modes are in scope. The harness refuses to run a task whose runtime_modes_in_scope does not include the configured runtime mode (when non-empty).",
      "items": {
        "type": "string",
        "enum": [
          "full_contract",
          "no_validation",
          "no_agent_safe",
          "no_proposal_gate",
          "no_refusal",
          "no_audit_chain",
          "no_runtime_enforcement"
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "hide_stdout": {
      "type": "boolean",
      "description": "When true, the harness withholds command stdout from the model's observation feedback (blind observation). Used for the audit blind-vs-sighted demonstration; defaults to false (sighted)."
    },
    "contract_arm": {
      "type": "string",
      "enum": ["told", "untold"],
      "description": "The contract-in-prompt axis of the specify-vs-enforce 2x2. 'told' (default) presents the full manifest; 'untold' withholds the manifest facts that specify this task's load-bearing mechanism, so the agent is not told the constraint. Realizes cells C/D vs A/B."
    }
  }
}
