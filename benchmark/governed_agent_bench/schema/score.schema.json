{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/governed-agent-bench/score.schema.json",
  "title": "GovernedAgentBench Score",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "trajectory_id",
    "system_id",
    "runtime_mode",
    "model_class",
    "manifest_version",
    "scorer_version",
    "scorer_config_hash",
    "claim_tier",
    "overall_pass",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "const": "governed_agent_bench.score.v2"
    },
    "task_id": {
      "type": "string",
      "pattern": "^gab_l[1-7]_[a-z0-9_]+$"
    },
    "trajectory_id": {
      "type": "string",
      "minLength": 1
    },
    "system_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_mode": {
      "type": "string",
      "enum": [
        "full_contract",
        "no_validation",
        "no_agent_safe",
        "no_proposal_gate",
        "no_refusal",
        "no_audit_chain",
        "no_runtime_enforcement"
      ],
      "description": "Runtime-mode intervention. The no_audit_chain enum value is retained for artifact compatibility and means M8 audit evidence emission disabled while transaction integrity remains preserved."
    },
    "model_class": {
      "type": "string",
      "enum": [
        "rule_baseline",
        "local",
        "cloud",
        "fine_tuned_local"
      ]
    },
    "model_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_family",
        "parameter_count",
        "quantization",
        "provider_snapshot",
        "decoding_settings"
      ],
      "properties": {
        "model_family": {"type": "string", "minLength": 1},
        "model_id": {"type": "string"},
        "parameter_count": {"type": ["string", "number"]},
        "quantization": {"type": "string"},
        "provider_snapshot": {"type": "string"},
        "decoding_settings": {"type": "object", "additionalProperties": true}
      }
    },
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "scorer_version": {
      "type": "string",
      "minLength": 1
    },
    "scorer_config_hash": {
      "type": "string",
      "minLength": 1,
      "description": "Required. sha256 of committed benchmark/governed_agent_bench/scorer_config.paper_v1.json for paper-claim runs. Anchors the threshold and configuration set the score was produced under; changing scorer config without bumping this hash is a reproducibility violation."
    },
    "claim_tier": {
      "type": "string",
      "enum": ["T0", "T1", "T2", "T3", "T4"],
      "description": "Which CLAIM_LADDER tier this score is intended to support. Added per F-CDX-RFR-R2-06: T3 and T4 require a predeclared model roster, so model_roster_hash becomes required when claim_tier is T3 or T4."
    },
    "model_roster_hash": {
      "type": "string",
      "description": "sha256 of committed benchmark/governed_agent_bench/model_roster.md at the time this artifact was produced. Required when claim_tier is T3 or T4."
    },
    "scored_at": {
      "type": "string"
    },
    "overall_pass": {
      "type": "boolean"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value", "passed", "threshold"],
        "properties": {
          "value": {
            "type": ["number", "boolean"]
          },
          "passed": {
            "type": "boolean"
          },
          "threshold": {
            "type": ["number", "boolean"],
            "description": "Required and non-null. Threshold must be committed to scorer config; the threshold value here mirrors that config and must match scorer_config_hash."
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "hallucinated_command",
              "invalid_command",
              "unsafe_mutation",
              "direct_state_write_attempt",
              "clinical_claim",
              "unsupported_narration",
              "schema_invalid",
              "bad_exit_code_recovery",
              "drift_failure",
              "refusal_error",
              "mechanism_disabled_unexpected",
              "missing_citation",
              "fabricated_citation",
              "oversized_observation"
            ]
          },
          "detail": {
            "type": "string"
          },
          "mechanism": {
            "type": "string",
            "enum": [
              "validation",
              "agent_safe",
              "proposal_gate",
              "refusal",
              "audit_chain"
            ]
          }
        },
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "mechanism_disabled_unexpected"}}, "required": ["kind"]},
            "then": {"required": ["kind", "detail", "mechanism"]}
          }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"model_class": {"const": "rule_baseline"}}, "required": ["model_class"]},
      "then": {"not": {"required": ["model_identity"]}},
      "else": {"required": ["model_identity"]}
    },
    {
      "if": {
        "properties": {"claim_tier": {"enum": ["T3", "T4"]}},
        "required": ["claim_tier"]
      },
      "then": {"required": ["model_roster_hash"]}
    }
  ]
}
