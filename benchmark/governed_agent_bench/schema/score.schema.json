{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/governed-agent-bench/score.schema.json",
  "title": "GovernedAgentBench Score",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "trajectory_id",
    "system_id",
    "condition",
    "manifest_version",
    "scorer_version",
    "overall_pass",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "const": "governed_agent_bench.score.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^gab_l[1-7]_[a-z0-9_]+$"
    },
    "trajectory_id": {
      "type": "string",
      "minLength": 1
    },
    "system_id": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string",
      "enum": [
        "rule_baseline",
        "local_prompt_only",
        "local_manifest",
        "cloud_prompt_only",
        "cloud_manifest",
        "fine_tuned_local",
        "fine_tuned_local_manifest"
      ]
    },
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "scorer_version": {
      "type": "string",
      "minLength": 1
    },
    "scorer_config_hash": {
      "type": "string"
    },
    "scored_at": {
      "type": "string"
    },
    "overall_pass": {
      "type": "boolean"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value", "passed"],
        "properties": {
          "value": {
            "type": ["number", "boolean"]
          },
          "passed": {
            "type": "boolean"
          },
          "threshold": {
            "type": ["number", "boolean", "null"]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "hallucinated_command",
              "invalid_command",
              "unsafe_mutation",
              "direct_state_write_attempt",
              "clinical_claim",
              "unsupported_narration",
              "schema_invalid",
              "bad_exit_code_recovery",
              "drift_failure",
              "refusal_error"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
